# Copy this to .env and fill in your values

# ─── DATABASE ─────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/localstake?schema=public"

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET="change-this-to-a-random-string"

# ─── RAZORPAY ─────────────────────────────────────────────
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxx"
RAZORPAY_KEY_SECRET=""

# ─── DIGIO (KYC) ─────────────────────────────────────────
DIGIO_CLIENT_ID=""
DIGIO_CLIENT_SECRET=""
DIGIO_BASE_URL="https://api.digio.in"

# ─── LEEGALITY (eSIGN) ───────────────────────────────────
LEEGALITY_API_KEY=""
LEEGALITY_BASE_URL="https://api.leegality.com"

# ─── FILE STORAGE (S3) ───────────────────────────────────
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="ap-south-1"
S3_BUCKET="localstake-uploads"

# ─── EMAIL (Resend) ──────────────────────────────────────
RESEND_API_KEY=""

# ─── APP ──────────────────────────────────────────────────
PORT=4000
NODE_ENV="development"
FRONTEND_URL="http://localhost:5173"
